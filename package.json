{
  "name": "mobx-restful-shadcn",
  "version": "1.7.2",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "install": "shadcn-helper install",
    "test": "lint-staged  &&  git add .",
    "registry:build": "shadcn build",
    "dev": "next dev",
    "build": "npm run registry:build  &&  next build --webpack",
    "start": "next start"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "edkit": "^1.2.7",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^1.21.0",
    "mobx": "^6.16.1",
    "mobx-i18n": "^0.7.2",
    "mobx-react": "^9.2.2",
    "mobx-react-helper": "^0.5.1",
    "mobx-restful": "^2.1.4",
    "next": "^16.2.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-utility": "^4.6.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@octokit/openapi-types": "^27.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mobx-github": "^0.6.2",
    "shadcn": "^4.11.0",
    "shadcn-helper": "^0.5.6",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write",
      "biome format --write"
    ],
    "*.{md,css,json}": "biome format --write"
  }
}
